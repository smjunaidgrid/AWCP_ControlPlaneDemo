            "type": "timeseries",
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "histogram_quantile(0.50, rate(awcp_awcp_ask_duration_seconds_bucket[5m]))",
