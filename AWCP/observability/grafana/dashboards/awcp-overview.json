{
    "__inputs": [],
    "__requires": [],
    "annotations": {
        "list": []
    },
    "description": "AWCP Agent Workforce Control Plane — Observability Overview",
    "editable": true,
    "graphTooltip": 1,
    "id": null,
    "panels": [

        {
            "gridPos": { "h": 3, "w": 6, "x": 0, "y": 0 },
            "id": 1,
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background"
            },
            "title": "Total /ask Requests (1h)",
            "type": "stat",
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "increase(awcp_awcp_ask_requests_total[1h])",
                    "legendFormat": "Requests"
                }
            ]
        },

        {
            "gridPos": { "h": 3, "w": 6, "x": 6, "y": 0 },
            "id": 2,
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background",
                "thresholds": {
                    "steps": [
                        { "color": "green", "value": null },
                        { "color": "yellow", "value": 0.9 },
                        { "color": "red", "value": 0.95 }
                    ]
                }
            },
            "title": "Success Rate",
            "type": "stat",
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "rate(awcp_awcp_ask_requests_total{status=\"success\"}[5m]) / rate(awcp_awcp_ask_requests_total[5m])",
                    "legendFormat": "Success Rate"
                }
            ]
        },

        {
            "gridPos": { "h": 3, "w": 6, "x": 12, "y": 0 },
            "id": 3,
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background"
            },
            "title": "P95 /ask Latency (s)",
            "type": "stat",
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "histogram_quantile(0.95, rate(awcp_awcp_ask_duration_seconds_bucket[5m]))",
                    "legendFormat": "P95 Latency"
                }
            ]
        },

        {
            "gridPos": { "h": 3, "w": 6, "x": 18, "y": 0 },
            "id": 4,
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background",
                "thresholds": {
                    "steps": [
                        { "color": "green", "value": null },
                        { "color": "yellow", "value": 1 },
                        { "color": "red", "value": 5 }
                    ]
                }
            },
            "title": "Tool Failures (1h)",
            "type": "stat",
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "increase(awcp_awcp_tool_failures_total[1h])",
                    "legendFormat": "Failures"
